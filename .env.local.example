# Supabase (create project at https://supabase.com)
# Then run the SQL in supabase/schema.sql in the SQL Editor
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only this email can see the admin bar and edit/delete resume content. Others can still log in but get no edit powers.
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# Set to "true" only when creating your first account. Then set to "false" and disable sign-ups in Supabase (Authentication > Providers > Email > Enable sign ups OFF) so no one else can register.
NEXT_PUBLIC_ALLOW_SIGNUP=false
